# Copy this file to .env and fill in your own values

# MongoDB Atlas (cloud database - recommended for production)
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/mini_ecommerce?retryWrites=true&w=majority

# Or Local MongoDB (for development only):
# MONGO_URI=mongodb://127.0.0.1:27017/mini_ecommerce

# Any long random string - used to sign login tokens
JWT_SECRET=change_this_to_a_long_random_secret_key

# Port the backend server runs on
PORT=5000
