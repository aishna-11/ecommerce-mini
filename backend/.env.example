# Copy this file to .env and fill in your own values

# Local MongoDB:
MONGO_URI=mongodb://127.0.0.1:27017/mini_ecommerce

# Or MongoDB Atlas (cloud, free tier):
# MONGO_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/mini_ecommerce

# Any long random string - used to sign login tokens
JWT_SECRET=change_this_to_a_long_random_secret_key

# Port the backend server runs on
PORT=5000
